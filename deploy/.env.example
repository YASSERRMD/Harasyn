# Harasyn Environment Configuration

# Database
POSTGRES_PASSWORD=harasyn_dev_password

# JWT Secret (change in production!)
JWT_SECRET=dev_secret_change_in_production_at_least_32_chars_long

# API Configuration
PORT=8080
GATEWAY_PORT=8081
POLICY_WORKER_PORT=8082
SESSION_WORKER_PORT=8083
AUDIT_WORKER_PORT=8084

# Database URL (for local development)
DATABASE_URL=postgres://harasyn:harasyn_dev_password@localhost:5432/harasyn?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# NATS
NATS_URL=nats://localhost:4222

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
