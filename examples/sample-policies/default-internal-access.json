{
  "name": "Default Internal Access",
  "description": "Allow access to internal resources for trusted devices and users",
  "policy_type": "access",
  "effect": "allow",
  "priority": 100,
  "conditions": [
    {"type": "device_trust", "operator": ">=", "value": "60"},
    {"type": "user_trust", "operator": ">=", "value": "50"},
    {"type": "resource_sensitivity", "operator": "in", "value": "public,internal"}
  ]
}
